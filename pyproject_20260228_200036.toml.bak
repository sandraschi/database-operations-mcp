[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "database-operations-mcp"
version = "1.4.1"
description = "Comprehensive FastMCP 3.0 server for database operations (SQL, NoSQL, Vector), browser bookmarks, and system tools."
readme = "README.md"
requires-python = ">=3.12"
license = { text = "MIT" }
authors = [
    { name = "Your Name", email = "your.email@example.com" }
]
classifiers = [
    "Development Status :: 4 - Beta",
    "Intended Audience :: Developers",
    "License :: OSI Approved :: MIT License",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.10",
    "Programming Language :: Python :: 3.11",
    "Programming Language :: Python :: 3.12",
]

dependencies = [
    "chromadb>=0.4.15",
    "pymongo>=4.6.0",
    "psycopg2-binary>=2.9.9",
    "duckdb>=0.9.0",
    "aiomysql>=0.2.0",
    "redis>=5.0.0",
    "aiohttp>=3.9.0",
    "rich>=13.7.0",
    "psutil>=5.9.0",
    "fastmcp>=3.0.0",
    "aiofiles>=23.2.0",
    "aiosqlite>=0.19.0",
    "pydantic>=2.5.0",
    "requests>=2.31.0",
    "beautifulsoup4>=4.12.0",
    # py-key-value-aio[disk] is managed by fastmcp - don't pin here to avoid conflicts
    "ruff>=0.14.0",
]

[project.optional-dependencies]
dev = [
    "ruff>=0.1.0",
    "mypy>=1.7.0",
    "pytest>=7.4.0",
    "pytest-asyncio>=0.21.0",
    "pytest-cov>=4.1.0",
]
ai = [
    "openai>=1.5.0",
]

[project.scripts]
database-operations-mcp = "database_operations_mcp.main:main"
browser-bookmarks = "browser_bookmarks_tools.mcp_server:main"

[dependency-groups]
dev = [
    "ruff>=0.1.0",
    "mypy>=1.7.0",
    "pytest>=7.4.0",
    "pytest-asyncio>=0.21.0",
    "pytest-cov>=4.1.0",
]

[tool.ruff]
line-length = 100
target-version = "py310"
exclude = [
    ".git",
    ".ruff_cache",
    ".venv",
    "mcpb",
    "dist",
    "build",
    "target",
]

[tool.ruff.lint]
select = ["E", "F", "I", "N", "W", "UP"]
ignore = ["E501", "W291", "N805", "N812", "F841", "UP006", "UP035", "UP045", "UP015", "E402", "I001"]

[tool.ruff.lint.per-file-ignores]
"__init__.py" = ["F401"]

[tool.mypy]
python_version = "3.10"
warn_return_any = true
warn_unused_configs = true
disallow_untyped_defs = false

[tool.pytest.ini_options]
minversion = "7.0"
addopts = "-ra -q --strict-markers"
testpaths = ["tests"]
asyncio_mode = "auto"

