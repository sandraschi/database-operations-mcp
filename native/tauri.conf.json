{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Database Operations MCP",
    "version": "0.1.0",
    "identifier": "com.sandraschi.database-operations-mcp",
    "build": {
        "frontendDist": "../web_sota/dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Database Operations MCP",
                "width": 1280,
                "height": 860,
                "minWidth": 700,
                "minHeight": 500,
                "resizable": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:10708 ipc: http://ipc.localhost; img-src 'self' data: http://127.0.0.1:10708; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
        }
    },
    "bundle": {
        "active": true,
        "targets": ["nsis"],
        "icon": ["icons/icon.png", "icons/icon.ico"],
        "resources": [
            "resources/database-operations-mcp-backend.exe"],
        "windows": {
            "webviewInstallMode": {
                "type": "skip"
            },
            "nsis": {
                "installMode": "currentUser",
                "installerHooks": "./windows/hooks.nsh"
            }
        }
    },
    "plugins": {}
}



